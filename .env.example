# ===========================================
# Homelab Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# -------------------------------------------
# System Paths
# -------------------------------------------

# Path to appdata (container configs) - preferably SSD
APPDATA_PATH=/opt/homelab/appdata

# Path to data storage - can be HDD
DATA_PATH=/mnt/data

# -------------------------------------------
# System Settings
# -------------------------------------------

# Timezone (for containers)
TZ=Europe/Bratislava

# Local domain for internal services
LOCAL_DOMAIN=home.local

# External domain for Cloudflare Tunnel access
EXTERNAL_DOMAIN=1218217.xyz

# -------------------------------------------
# User IDs
# -------------------------------------------

# Run containers as this user (use `id` command to find)
PUID=1000
PGID=1000

# -------------------------------------------
# Cloudflare Tunnel
# -------------------------------------------

# Token from Cloudflare Zero Trust → Tunnels
# Get it at: https://one.dash.cloudflare.com/ → Networks → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# -------------------------------------------
# SSL Certificates (Let's Encrypt via Cloudflare DNS)
# -------------------------------------------

# Email for Let's Encrypt notifications
ACME_EMAIL=your-email@example.com

# Cloudflare API Token for DNS challenge
# Create at: My Profile → API Tokens → Create Token
# Permissions: Zone:DNS:Edit for zone 1218217.xyz
CF_DNS_API_TOKEN=your-cloudflare-api-token

# -------------------------------------------
# Samba Users
# -------------------------------------------

# Samba user passwords (set your own)
SAMBA_USER_ANDREW=andrew
SAMBA_PASS_ANDREW=changeme

SAMBA_USER_YULIIA=yuliia
SAMBA_PASS_YULIIA=changeme

# -------------------------------------------
# Immich
# -------------------------------------------

# Database password
IMMICH_DB_PASSWORD=changeme

# -------------------------------------------
# AdGuard Home
# -------------------------------------------

# Initial admin password (change after first login)
ADGUARD_PASSWORD=changeme

# -------------------------------------------
# OPDS Generator
# -------------------------------------------

# Admin credentials for /resync endpoint (Basic Auth)
OPDS_ADMIN_USER=admin
OPDS_ADMIN_TOKEN=changeme

# -------------------------------------------
# Shared HTTP Basic Auth (Traefik basic-auth@docker middleware)
# -------------------------------------------

# Used by feed services that podcast/OPDS apps consume (ytpod, opds, opml)
# instead of Authelia — clients subscribe with user:pass@host. htpasswd format,
# multiple users comma-separated. IMPORTANT: wrap the value in single quotes and
# keep single $ — deploy.sh does `source .env` (bash), single quotes stop bash
# from mangling $ (e.g. $$ -> PID). Generate:
#   htpasswd -nbB feeds 'your-password'   # then wrap output in '...'
BASIC_AUTH_USERS='feeds:$2y$05$changeme'

# -------------------------------------------
# YouTube Podcast (vod2pod-rss / ytpod)
# -------------------------------------------

# Optional: YouTube Data API v3 key. Without it feeds are capped at ~15 items
# and channel avatars are missing. Get one at console.cloud.google.com.
YT_API_KEY=

# -------------------------------------------
# Authelia (SSO Authentication)
# -------------------------------------------

# Generate secrets with: openssl rand -base64 32
AUTHELIA_JWT_SECRET=generate-with-openssl-rand-base64-32
AUTHELIA_SESSION_SECRET=generate-with-openssl-rand-base64-32
AUTHELIA_STORAGE_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# User passwords are stored in services/authelia/config/users_database.yml
# Generate password hash: docker run --rm authelia/authelia:latest authelia crypto hash generate argon2 --password 'your-password'
